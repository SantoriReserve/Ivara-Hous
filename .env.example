# OpenAI — required for Creator Development Assessment
OPENAI_API_KEY=your_openai_api_key_here

# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Make.com — Creator Application form webhook
MAKE_CREATOR_APPLICATION_WEBHOOK_URL=your_make_webhook_url_here

# Stripe — 40-Day Creator Development Plan checkout ($95 USD)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PRICE_ID=price_your_stripe_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Public site URL — used for Stripe success/cancel redirects
# Local: http://localhost:3000
# Production: https://ivara-hous.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — assessments + purchases (Phase 2) and auth (Phase 3A)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase Auth redirect allowlist (Dashboard → Authentication → URL Configuration):
# - Site URL: http://localhost:3000 (local) or https://ivara-hous.vercel.app (production)
# - Redirect URLs: http://localhost:3000/auth/callback and https://ivara-hous.vercel.app/auth/callback
